# Copia este archivo a .env y rellena los valores reales.
# Genera el secreto con: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=cambia-esto-por-un-valor-aleatorio

# Usuarios en formato JSON: {"usuario": "contraseña"}
APP_USERS={"admin": "cambia-esta-contraseña"}

# "true" activa el modo debug de Flask (solo desarrollo). Cualquier otro valor lo deja apagado.
FLASK_DEBUG=false

# Conexion a la base de datos
DATABASE_URL=sqlite:///history.db

# Almacenamiento del rate limiter: memory:// (dev) o redis://host:puerto (produccion)
RATELIMIT_STORAGE_URI=redis://localhost:6379
